# === LINE Bot Configuration ===
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# === Application ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=https://your-domain.ngrok.io

# === Storage ===
STORAGE_ROOT=./storage

# === Vendor API ===
VENDOR_API_KEY=your_vendor_api_key_here

# === Bootstrap Admin ===
# LINE User ID of the first manager (bootstrap)
BOOTSTRAP_ADMIN_LINE_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOOTSTRAP_ADMIN_NAME=系統管理員

# === LRS Service ===
LRS_CSV_PATH=./app/data/lrs_milepost.csv
LRS_MAX_DISTANCE_M=500
LRS_GRID_SIZE_DEG=0.01

# === Image Processing ===
MAX_IMAGE_SIZE_MB=10
THUMBNAIL_SIZE=300
ACCEPTED_IMAGE_FORMATS=image/jpeg,image/png,image/heic

# === PDF Parser ===
TESSERACT_CMD=tesseract
TESSERACT_LANG=chi_tra
