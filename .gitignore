# OS
.DS_Store
Thumbs.db

# Storage (runtime data - don't commit)
storage/cases/
storage/users/
storage/sessions/
storage/locks/

# Keep storage directories via .gitkeep
!storage/cases/.gitkeep
!storage/users/.gitkeep
!storage/sessions/.gitkeep
!storage/locks/.gitkeep

# Logs
*.log
logs/
*_log.txt
*_output.txt
uvicorn_stdout.txt
uvicorn_stderr.txt
server.log
ngrok.log
ngrok_out.log

# Local runtime / platform artifacts
rich_menu_ids.json
rich_menu_*.png
thumb_test.jpg
nul

# Generated docs and local exports
docx_content.txt
planning_doc_release.docx

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Temporary files
*.tmp
*.bak
