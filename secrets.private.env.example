# Copy this file to `secrets.private.env` and fill real secrets.
# Do NOT commit `secrets.private.env`.

# LINE channel credentials
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# External vendor access
VENDOR_API_KEY=your_vendor_api_key

# ngrok fixed-domain tunnel
NGROK_AUTHTOKEN=your_ngrok_authtoken
NGROK_DOMAIN=your-fixed-subdomain.ngrok-free.dev
